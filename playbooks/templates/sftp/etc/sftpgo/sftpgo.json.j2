    "resume_max_size": 0,
    "secret_min_entropy": 80,
    "temp_path": "",
    "proxy_protocol": 1,
    "proxy_allowed": [
{%- for proxy in _sftp_proxy_allowed %}
{%    set ip = proxy if proxy|ansible.utils.ipaddr else lookup('dig', proxy) %}
      "{{ ip }}"{% if not loop.last %},{% endif %}
{% endfor +%}
    ],
    "proxy_skipped": [],
    "startup_hook": "",
    "post_connect_hook": "",
    "post_disconnect_hook": "",
